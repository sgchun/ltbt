library(data.table)
source("../sim2/ltbt.R")

ukbpre <- "/lab-share/Pulmonary-Chun-e2/Public/data/ukb/wes500k/"

files <- list.files(paste(ukbpre, "ukbvep/", sep=''))
files <- files[grep("probdam_all.csv", files)]

gtfiles <- gsub("probdam_all.csv", "QC.probdam.gt", files)

ukb <- NULL

for (I in 1:length(files)) {
    FL <- files[I]
    print(FL)
    ukb0 <- read.csv(paste(ukbpre, "ukbvep/", FL, sep=''),
                     stringsAsFactors=FALSE)
    FL <- gtfiles[I]
    print(FL)
    ukbgt0 <-
        read.delim(paste(ukbpre, "ukbgt/probdam/", FL, sep=''), 
                   sep="\t", header=FALSE, stringsAsFactors=FALSE)

    stopifnot(nrow(ukb0) == nrow(ukbgt0))
    
    ukb <- rbind(ukb, cbind(ukb0,
                            qual=ukbgt0[, 1],
                            het=ukbgt0[, 2],
                            homalt=ukbgt0[, 3],
                            stringsAsFactors=FALSE))
}

rm(ukb0)
rm(ukbgt0)
gc()

alleles <- gsub(" ", "", gsub("'", "", ukb$alleles))
alleles <- sapply(alleles, function (alstr) {
       strsplit(substr(alstr, 2, nchar(alstr) - 1), ",")
   })
n.alleles <- sapply(alleles, function (al) {
       length(al)
   }, simplify=TRUE)
stopifnot(all(n.alleles == 2))
A1 <- sapply(alleles, function (al) {
       al[1]
   }, simplify=TRUE)
A2 <- sapply(alleles, function (al) {
       al[2]
   }, simplify=TRUE)

keys <- paste(ukb$locus.contig, ukb$locus.position, A1, A2, sep="_")
ukb <- cbind(ukb, key=keys, stringsAsFactors=FALSE)
ukb <- as.data.table(ukb)
setkey(ukb, key)
dim(ukb)

# qcfail: ukb
files.qc <- list.files(paste(ukbpre, "ukbqcfail/", sep=''))

ukb.qcfail.key <- c()

for (FL in files.qc) {
  print(FL)
  qcfail0 <-
    read.csv(paste(ukbpre, "ukbqcfail/", FL, sep=''),
             stringsAsFactors=FALSE)$rsid

  qcfail0 <- unlist(strsplit(qcfail0, ";", fixed=TRUE))

  ukb.qcfail.key <- c(ukb.qcfail.key, qcfail0)
}

rm(qcfail0)
gc()

length(ukb.qcfail.key)

########################################################################
## gnomAD

gnomad <- NULL

for (I in 1:22) {
    file <- paste("~/data/gnomad/2.1.1.liftover/",
                  "gnomad.exomes.r2.1.1.sites.", I,
                  ".liftover_grch38.probdam.popmax.tsv.gz", sep='')
    gnomad0 <- read.delim(file ,sep=" ", stringsAsFactors=FALSE, header=FALSE)

    gnomad <- rbind(gnomad, gnomad0)
}

colnames(gnomad)[1:6] <- c("CHRBP", "SNPID", "REF", "ALT", "FILTER", "POPMAX")

key <- paste(gsub(":", "_", gnomad$CHRBP, fixed=TRUE),
             gnomad$REF, gnomad$ALT,
             sep="_")

gnomad <- cbind(gnomad, key, stringsAsFactors=FALSE)
gnomad$POPMAX <- as.numeric(gnomad$POPMAX)

gnomad <- gnomad[!is.na(gnomad$POPMAX), ]

