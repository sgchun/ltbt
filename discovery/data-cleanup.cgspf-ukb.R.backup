# IPF
ipf <- read.csv("../qc/fibrosis_only.freeze_121521.white_probands.ukb_exome_bed.probdam.csv", stringsAsFactors=FALSE)

ipf <- ipf[, -which(colnames(ipf) %in% c("homref", "het", "homvar"))]
dim(ipf)

ipfgt <- read.delim("../qc/fibrosis_only.freeze_121521.white_probands.ukb_exome_bed.QC136.probdam.gt.gz", sep="\t", header=FALSE, stringsAsFactors=FALSE)

stopifnot(nrow(ipf) == nrow(ipfgt))
    
ipf <- cbind(ipf,
             qual=ipfgt[, 1],
             het=ipfgt[, 2],
             homalt=ipfgt[, 3],
             stringsAsFactors=FALSE)
rm(ipfgt)
gc()

qcfail.ipf <-
    read.csv("../qc/fibrosis_only.freeze_121521.white_probands.ukb_exome_bed.qcfail.csv", stringsAsFactors=FALSE)$rsid
qcfail.ipf <- unlist(strsplit(qcfail.ipf, ";", fixed=TRUE))
length(qcfail.ipf)

ipf <- ipf[ipf$locus.contig != "chrX", ]
dim(ipf)

alleles <- gsub(" ", "", gsub("'", "", ipf$alleles))
alleles <- sapply(alleles, function (alstr) {
       strsplit(substr(alstr, 2, nchar(alstr) - 1), ",")
   })
n.alleles <- sapply(alleles, function (al) {
       length(al)
   }, simplify=TRUE)
stopifnot(all(n.alleles == 2))
A1 <- sapply(alleles, function (al) {
       al[1]
   }, simplify=TRUE)
A2 <- sapply(alleles, function (al) {
       al[2]
   }, simplify=TRUE)

keys <- paste(ipf$locus.contig, ipf$locus.position, A1, A2, sep="_")
ipf <- cbind(ipf, key=keys, stringsAsFactors=FALSE)

## Exclude QC-failed sites
ipf.exclude <- which(ipf$key %in% ukb.qcfail.key)
length(ipf.exclude)

ipf <- ipf[ -ipf.exclude, ]
dim(ipf)

ukb.exclude <- which(ukb$key %in% qcfail.ipf)
length(ukb.exclude)

ukb <- ukb[ -ukb.exclude, ]
dim(ukb)

#####
## recount AC
AC.new <-
    sapply(ipf$het,
           function(x) length(strsplit(x, ",", fixed=TRUE)[[1]]),
           simplify=TRUE)
AC.new <- AC.new +
    sapply(ipf$homalt,
           function(x) length(strsplit(x, ",", fixed=TRUE)[[1]]),
           simplify=TRUE) * 2

# plot(ipf$AC, AC.new, pch=19, cex=0.2)
# abline(0, 1)

ipf$AC <- AC.new
range(ipf$AC)

ipf <- ipf[ipf$AC > 0, ]
dim(ipf)

